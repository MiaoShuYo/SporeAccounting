<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!--
      Only the official NuGet source is required by default.
      If you are in a network that blocks api.nuget.org (e.g. mainland China),
      uncomment the line below and comment out the official source:
        <add key="nuget-cn" value="https://nuget.cdn.azure.cn/v3/index.json" />
    -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
  <!-- Disable vulnerability audit that contacts remote sources; re-enable per-build if desired -->
  <packageSourceCredentials />
  <config>
    <add key="auditSources" value="" />
  </config>
</configuration>
